controller:
  address: "controller.example.com:9443"
  tls:
    cert: "/etc/encodeswarmr/certs/agent.crt"
    key:  "/etc/encodeswarmr/certs/agent.key"
    ca:   "/etc/encodeswarmr/certs/ca.crt"
  reconnect:
    initial_delay: 5s
    max_delay: 5m
    multiplier: 2.0

agent:
  hostname: ""        # auto-detected from os.Hostname() if empty
  work_dir: "/var/lib/encodeswarmr-agent/work"
  log_dir:  "/var/log/encodeswarmr-agent"
  offline_db: "/var/lib/encodeswarmr-agent/offline.db"
  heartbeat_interval: 30s
  poll_interval: 10s
  cleanup_on_success: true
  keep_failed_jobs: 10

tools:
  ffmpeg:   "/usr/bin/ffmpeg"
  ffprobe:  "/usr/bin/ffprobe"
  x265:     "/usr/bin/x265"
  x264:     "/usr/bin/x264"
  svt_av1:  ""
  avs_pipe: ""          # AviSynth not available on Linux
  vspipe:   ""          # Set if VapourSynth is installed
  dovi_tool: ""         # optional: path to dovi_tool binary for Dolby Vision profile detection

gpu:
  enabled: true
  vendor: ""          # auto-detect; override: nvidia | intel | amd
  max_vram_mb: 0      # 0 = no limit
  monitor_interval: 5s

allowed_shares:
  - "/mnt/nas/media"
  - "/mnt/nas/encodes"

logging:
  level: info
  format: json
  max_size_mb: 100
  max_backups: 5
  compress: true
  stream_buffer_size: 1000
  stream_flush_interval: 1s

vnc:
  enabled: false
  port: 5900
