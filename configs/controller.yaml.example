server:
  host: "0.0.0.0"
  port: 8080
  read_timeout: 30s
  write_timeout: 30s

database:
  url: "postgres://distencoder:password@localhost:5432/distencoder"
  max_conns: 25
  min_conns: 5
  max_conn_lifetime: 1h
  migrations_path: "/usr/share/distributed-encoder/migrations"

grpc:
  host: "0.0.0.0"
  port: 9443
  tls:
    cert: "certs/controller.crt"
    key: "certs/controller.key"
    ca: "certs/ca.crt"

auth:
  session_ttl: 24h
  session_secret: "change-me"
  oidc:
    enabled: false
    provider_url: ""
    client_id: ""
    client_secret: ""
    redirect_url: "http://localhost:8080/auth/oidc/callback"
    auto_provision: false
    groups_claim: "groups"         # JWT claim containing group memberships
    default_role: "viewer"        # role when no group mapping matches
    # Map OIDC groups to application roles (admin > operator > viewer)
    role_mappings:
      # "encoding-admins": "admin"
      # "encoding-operators": "operator"
      # "encoding-viewers": "viewer"

logging:
  level: info
  format: json
  task_log_retention: 720h        # 30 days
  task_log_cleanup_interval: 6h
  task_log_max_lines_per_job: 500000

agent:
  auto_approve: false
  heartbeat_timeout: 90s
  dispatch_interval: 10s
  stale_threshold: 5m             # mark agents stale after no heartbeat

engine:
  tick_interval: 10s              # how often to check for pending jobs
  stale_threshold: 5m             # agent stale detection interval

# Agent binary upgrade distribution — place binaries in this directory
# and agents will self-upgrade via GET /api/v1/agent/upgrade/check
upgrade:
  binary_dir: ""                  # e.g. /var/lib/distributed-encoder/binaries

webhooks:
  worker_count: 4
  delivery_timeout: 10s
  max_retries: 3

tls:
  cert: "certs/controller.crt"
  key: "certs/controller.key"
  ca: "certs/ca.crt"

# Controller-side analysis: runs HDR detect, scene scanning, VMAF, and audio
# encoding directly on the controller using ffmpeg/ffprobe (requires the NAS
# to be accessible as NFS mounts).  Leave ffmpeg_bin/ffprobe_bin empty to
# auto-detect from PATH, or set explicit paths.
#
# path_mappings seeds the database on first startup.  After that, use the
# web UI or API (/api/v1/path-mappings) to manage them at runtime.
analysis:
  ffmpeg_bin:    "/usr/local/bin/ffmpeg"
  ffprobe_bin:   "/usr/local/bin/ffprobe"
  dovi_tool_bin: "/usr/local/bin/dovi_tool"
  concurrency:   2               # max simultaneous controller-side analysis jobs

  path_mappings:
    - name:    "NAS media"
      windows: "\\\\NAS01\\media"
      linux:   "/mnt/nas/media"
    - name:    "NAS encodes"
      windows: "\\\\NAS01\\encodes"
      linux:   "/mnt/nas/encodes"
    - name:    "NAS temp"
      windows: "\\\\NAS01\\temp"
      linux:   "/mnt/nas/temp"
