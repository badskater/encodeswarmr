# pg_hba.conf — managed by Ansible
# TYPE  DATABASE         USER              ADDRESS          METHOD

# Local connections
local   all              postgres                           peer
local   all              all                                peer

# IPv4 local
host    all              all               127.0.0.1/32     md5

# IPv6 local
host    all              all               ::1/128          md5

# Allow distributed-encoder controller to connect from its host(s)
{% for host in groups['controllers'] | default([]) %}
host    {{ db_name }}    {{ db_user }}     {{ hostvars[host]['ansible_host'] }}/32  md5
{% endfor %}
{% for host in groups['controllers_ha'] | default([]) %}
host    {{ db_name }}    {{ db_user }}     {{ hostvars[host]['ansible_host'] }}/32  md5
{% endfor %}
