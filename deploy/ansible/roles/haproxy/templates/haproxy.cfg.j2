# haproxy.cfg — managed by Ansible ({{ ansible_managed }})

global
    log /dev/log local0
    log /dev/log local1 notice
    chroot /var/lib/haproxy
    stats socket /run/haproxy/admin.sock mode 660 level admin expose-fd listeners
    stats timeout 30s
    user haproxy
    group haproxy
    daemon

defaults
    log     global
    mode    http
    option  httplog
    option  dontlognull
    timeout connect 5s
    timeout client  50s
    timeout server  50s
    errorfile 400  /etc/haproxy/errors/400.http
    errorfile 403  /etc/haproxy/errors/403.http
    errorfile 408  /etc/haproxy/errors/408.http
    errorfile 500  /etc/haproxy/errors/500.http
    errorfile 502  /etc/haproxy/errors/502.http
    errorfile 503  /etc/haproxy/errors/503.http
    errorfile 504  /etc/haproxy/errors/504.http

# ── Statistics page ────────────────────────────────────────────────────────────
listen stats
    bind *:9999
    mode  http
    stats enable
    stats uri /stats
    stats refresh 10s
    stats auth admin:haproxy-stats

# ── HTTP frontend — controller REST API + web UI ──────────────────────────────
frontend http_front
    bind *:{{ controller_http_port }}
    mode http
    option forwardfor
    default_backend http_controllers

backend http_controllers
    mode http
    balance roundrobin
    option httpchk GET /health
    http-check expect status 200
{% for host in groups['controllers_ha'] %}
    server {{ host }} {{ hostvars[host]['ansible_host'] }}:{{ controller_http_port }} check inter 5s fall 2 rise 2
{% endfor %}

# ── TCP frontend — gRPC + mTLS passthrough ────────────────────────────────────
frontend grpc_front
    bind *:{{ controller_grpc_port }}
    mode tcp
    option tcplog
    default_backend grpc_controllers

backend grpc_controllers
    mode tcp
    balance roundrobin
    option tcp-check
{% for host in groups['controllers_ha'] %}
    server {{ host }} {{ hostvars[host]['ansible_host'] }}:{{ controller_grpc_port }} check inter 5s fall 2 rise 2
{% endfor %}
