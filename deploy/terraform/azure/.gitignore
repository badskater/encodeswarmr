# Terraform state files — never commit
*.tfstate
*.tfstate.*
*.tfstate.backup

# tfvars may contain secrets — never commit
terraform.tfvars
*.auto.tfvars

# Terraform working directories
.terraform/
.terraform.lock.hcl

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Crash logs
crash.log
crash.*.log

# Plan output files (may contain sensitive values)
*.tfplan
tfplan
