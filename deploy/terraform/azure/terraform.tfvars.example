# ─── terraform.tfvars.example ─────────────────────────────────────────────────
# Copy this file to terraform.tfvars and fill in the values.
# Never commit terraform.tfvars to source control — it contains secrets.
#
#   cp terraform.tfvars.example terraform.tfvars

# ─── General ──────────────────────────────────────────────────────────────────
location            = "westus2"
resource_group_name = "encodeswarmr-rg"
environment         = "prod"

# ─── High Availability ────────────────────────────────────────────────────────
# Set to true to deploy:
#   - 2 controller VMs (zone 1 and zone 2)
#   - Standard Azure Load Balancer
#   - Zone-redundant PostgreSQL Flexible Server
#   - ZRS storage replication
enable_ha = false

# ─── VM Sizing ────────────────────────────────────────────────────────────────
# Controller: general-purpose workload (web UI, job dispatch, DB access)
controller_vm_size = "Standard_D2s_v5"

# Agents: compute-optimized for encoding workloads
# Standard_F8s_v2  — 8 vCPU,  16 GB RAM  (good baseline)
# Standard_F16s_v2 — 16 vCPU, 32 GB RAM  (heavier x265 workloads)
# Standard_F32s_v2 — 32 vCPU, 64 GB RAM  (large-scale concurrent encodes)
agent_vm_size = "Standard_F8s_v2"

# Initial number of agent instances in the VMSS (can be scaled later)
agent_count = 2

# ─── PostgreSQL ───────────────────────────────────────────────────────────────
db_sku_name       = "GP_Standard_D2s_v3"
db_storage_mb     = 65536   # 64 GB — increase for large job log retention
db_admin_login    = "encodeswarmr_admin"
db_version        = "16"

# SENSITIVE: set via TF_VAR_db_admin_password env var or in terraform.tfvars
# Do NOT commit this value.
db_admin_password = "change-me-use-a-strong-password"

# ─── Networking ───────────────────────────────────────────────────────────────
vnet_address_space       = "10.10.0.0/16"
controller_subnet_prefix = "10.10.1.0/24"
agent_subnet_prefix      = "10.10.2.0/24"
database_subnet_prefix   = "10.10.3.0/24"
storage_subnet_prefix    = "10.10.4.0/24"

# Restrict SSH access to your IP(s). Leave empty to deny SSH from all public IPs.
# Example: ["203.0.113.10/32", "198.51.100.0/24"]
allowed_ssh_cidrs = []

# ─── SSH ──────────────────────────────────────────────────────────────────────
ssh_public_key_path = "~/.ssh/id_rsa.pub"

# ─── Application ──────────────────────────────────────────────────────────────
encodeswarmr_version     = "1.0.4"
controller_docker_image = "ghcr.io/badskater/encodeswarmr-controller:1.0.4"

# ─── Storage ──────────────────────────────────────────────────────────────────
# Premium: required for NFS protocol (lower latency, better for encoding I/O)
# Standard: SMB only, cheaper, sufficient for moderate workloads
storage_account_tier = "Premium"

# Total quota per share in GB (media, encodes each get this amount)
file_share_quota_gb = 5120
