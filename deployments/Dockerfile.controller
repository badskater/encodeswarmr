# ── Stage 1: Web UI ───────────────────────────────────────────────────────────
FROM node:22-alpine AS web-builder
WORKDIR /web
# Copy lockfile and manifest first for better layer caching
COPY web/package.json web/package-lock.json ./
RUN npm ci
COPY web/ .
RUN npm run build

# ── Stage 2: Go binary ────────────────────────────────────────────────────────
FROM golang:1.25-alpine AS go-builder
ARG VERSION=dev
RUN apk add --no-cache git
WORKDIR /src
# Download deps before copying source for better layer caching
COPY go.mod go.sum ./
RUN go mod download
# Copy source (web/dist is excluded by .dockerignore)
COPY . .
# Overwrite with the freshly built web UI
COPY --from=web-builder /web/dist ./web/dist
RUN CGO_ENABLED=0 GOOS=linux GOARCH=amd64 \
    go build -ldflags="-s -w -X main.Version=${VERSION}" \
    -o /controller ./cmd/controller

# ── Stage 3: FFmpeg 7 ─────────────────────────────────────────────────────────
# mwader/static-ffmpeg provides statically-linked FFmpeg builds that include:
#   libvmaf      — VMAF quality scoring
#   libx265      — HEVC encoder with HDR10, HDR10+, HLG metadata passthrough
#   libx264      — H.264 encoder
#   libopus      — Opus audio encoder
#   libfdk-aac   — High-quality AAC encoder
#   libflac      — FLAC audio (also available as native encoder)
#   HDR/DV       — Full HDR10/HDR10+/HLG/Dolby Vision stream and side-data support
# Static binaries require no runtime libraries.
FROM mwader/static-ffmpeg:latest AS ffmpeg-source

# ── Stage 4: dovi_tool ────────────────────────────────────────────────────────
# dovi_tool is an optional binary for precise Dolby Vision RPU profile extraction.
# The musl static build runs on any Linux without extra libraries.
FROM debian:bookworm-slim AS tools-fetcher
ARG DOVI_TOOL_VERSION=2.1.3
RUN apt-get update && apt-get install -y --no-install-recommends \
        ca-certificates \
        curl \
    && rm -rf /var/lib/apt/lists/* \
    && curl -fsSL \
        "https://github.com/quietvoid/dovi_tool/releases/download/${DOVI_TOOL_VERSION}/dovi_tool-${DOVI_TOOL_VERSION}-x86_64-unknown-linux-musl.tar.gz" \
       | tar xz -C /usr/local/bin \
    && chmod +x /usr/local/bin/dovi_tool

# ── Stage 5: Runtime ─────────────────────────────────────────────────────────
FROM debian:bookworm-slim
LABEL org.opencontainers.image.title="Distributed Encoder Controller" \
      org.opencontainers.image.description="Orchestrates distributed video encoding with HA, cloud storage, scheduling, and plugins" \
      org.opencontainers.image.source="https://github.com/badskater/distributed-encoder" \
      org.opencontainers.image.licenses="AGPL-3.0"
RUN apt-get update && apt-get install -y --no-install-recommends \
        ca-certificates \
        tzdata \
    && rm -rf /var/lib/apt/lists/*

COPY --from=go-builder   /controller                  /app/controller
COPY --from=go-builder   /src/internal/db/migrations  /app/migrations
COPY --from=ffmpeg-source /ffmpeg                      /usr/local/bin/ffmpeg
COPY --from=ffmpeg-source /ffprobe                     /usr/local/bin/ffprobe
COPY --from=tools-fetcher /usr/local/bin/dovi_tool     /usr/local/bin/dovi_tool

WORKDIR /app
EXPOSE 8080 9443
ENTRYPOINT ["/app/controller", "run"]
