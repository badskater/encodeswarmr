# Database
DATABASE_URL=postgres://distencoder:password@localhost:5432/distencoder
POSTGRES_PASSWORD=changeme

# Auth — minimum 32 characters
AUTH_SESSION_SECRET=change-me-in-production-min-32-chars

# OIDC (optional — leave blank to disable)
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=

# TLS certificate paths
TLS_CERT_FILE=certs/controller.crt
TLS_KEY_FILE=certs/controller.key
TLS_CA_FILE=certs/ca.crt
