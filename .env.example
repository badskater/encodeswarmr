# ─── Database ────────────────────────────────────────────────────────────────
# Password for the PostgreSQL encodeswarmr user (used by docker-compose)
POSTGRES_PASSWORD=changeme

# Full database URL used by the controller (overrides controller.yaml database.url)
# DATABASE_URL=postgres://encodeswarmr:changeme@postgres:5432/encodeswarmr

# ─── Session auth ─────────────────────────────────────────────────────────────
# Must be at least 32 characters. Generate with: openssl rand -hex 32
# Overrides controller.yaml auth.session_secret
AUTH_SESSION_SECRET=change-me-in-production-min-32-chars

# ─── OIDC SSO (optional — leave blank to disable) ────────────────────────────
# AUTH_OIDC_CLIENT_SECRET=

# ─── SMTP email (optional — leave blank to disable) ──────────────────────────
# Overrides controller.yaml smtp.password
SMTP_PASSWORD=

# ─── Notification channels (optional) ────────────────────────────────────────
# Telegram Bot API token from @BotFather
TELEGRAM_BOT_TOKEN=
# Pushover application API token
PUSHOVER_APP_TOKEN=
# ntfy Bearer token for private topics (optional)
NTFY_TOKEN=

# ─── Cloud storage credentials (optional) ────────────────────────────────────
# AWS S3
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# Google Cloud Storage
# GOOGLE_APPLICATION_CREDENTIALS=/app/gcp-sa.json
# Azure Blob Storage
# AZURE_STORAGE_ACCOUNT=
# AZURE_STORAGE_KEY=
