# ─── Database ────────────────────────────────────────────────────────────────
# Password for the PostgreSQL distencoder user (used by docker-compose)
POSTGRES_PASSWORD=changeme

# Connection details used by the controller
DE_DB_HOST=postgres
DE_DB_PORT=5432
DE_DB_NAME=distencoder
DE_DB_USER=distencoder
DE_DB_PASS=changeme

# ─── HTTP / gRPC listen ───────────────────────────────────────────────────────
DE_HTTP_PORT=8080
DE_GRPC_PORT=9443

# ─── mTLS certificates (paths inside the container) ──────────────────────────
DE_GRPC_TLS_CERT=/certs/server.crt
DE_GRPC_TLS_KEY=/certs/server.key
DE_GRPC_TLS_CA=/certs/ca.crt

# ─── Session auth ─────────────────────────────────────────────────────────────
# Must be at least 32 characters. Generate with: openssl rand -hex 32
DE_SESSION_SECRET=change-me-in-production-min-32-chars

# ─── Webhook HMAC signing (optional) ─────────────────────────────────────────
# If set, outgoing webhook payloads include an X-Hub-Signature-256 header
DE_WEBHOOK_HMAC_SECRET=

# ─── OIDC SSO (optional — leave blank to disable) ────────────────────────────
# Set DE_OIDC_PROVIDER_URL to enable OpenID Connect login
DE_OIDC_PROVIDER_URL=
DE_OIDC_CLIENT_ID=
DE_OIDC_CLIENT_SECRET=
# Must match the redirect URI configured in your identity provider
DE_OIDC_REDIRECT_URL=http://localhost:8080/auth/oidc/callback
# Set to true to auto-create local accounts on first OIDC login
DE_OIDC_AUTO_PROVISION=false

# ─── Agent behaviour ──────────────────────────────────────────────────────────
# Set to true to skip manual approval for new agents (NOT recommended in production)
DE_AGENT_AUTO_APPROVE=false

# ─── Log retention ────────────────────────────────────────────────────────────
# How long to keep per-task log lines in the database (default 30 days)
DE_TASK_LOG_RETENTION=720h
